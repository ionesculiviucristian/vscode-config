{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "extension": {
      "additionalProperties": false,
      "properties": {
        "description": {
          "minLength": 1,
          "type": "string"
        },
        "id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9-]*\\.[A-Za-z0-9][A-Za-z0-9._-]*$",
          "type": "string"
        },
        "name": {
          "minLength": 1,
          "type": "string"
        },
        "requirements": {
          "items": {
            "$ref": "#/definitions/requirement"
          },
          "minItems": 1,
          "type": "array"
        },
        "settings": {
          "$ref": "#/definitions/settings"
        },
        "version": {
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "type": "string"
        }
      },
      "required": ["description", "id", "name"],
      "type": "object"
    },
    "requirement": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "minLength": 1,
          "type": "string"
        },
        "url": {
          "format": "uri",
          "type": "string"
        }
      },
      "required": ["name", "url"],
      "type": "object"
    },
    "profile": {
      "additionalProperties": false,
      "properties": {
        "extends": {
          "items": {
            "pattern": "^[a-z0-9][a-z0-9-]*$",
            "type": "string"
          },
          "minItems": 1,
          "type": "array",
          "uniqueItems": true
        },
        "extensions": {
          "items": {
            "$ref": "#/definitions/extension"
          },
          "minItems": 1,
          "type": "array"
        },
        "id": {
          "pattern": "^[a-z0-9][a-z0-9-]*$",
          "type": "string"
        },
        "name": {
          "minLength": 1,
          "type": "string"
        },
        "primary": {
          "const": true
        },
        "settings": {
          "$ref": "#/definitions/settings"
        }
      },
      "required": ["extensions", "id", "name"],
      "type": "object"
    },
    "settings": {
      "minProperties": 1,
      "type": "object"
    }
  },
  "items": {
    "$ref": "#/definitions/profile"
  },
  "minItems": 1,
  "title": "VS Code profiles configuration",
  "type": "array"
}
