<%- include('partials/header.ejs', { profiles, sortProfiles, slugify }); -%>

## List of available profiles
<% profiles.sort(sortProfiles).forEach(function(profile){ %>
<%- `### ${profile.name}` -%>
<% if (profile.settings) { %>
<%- `${profile.settings}` -%>
<% } %>
<% profile.extensions.sort(sortExtensions).forEach(function(extension){ %>
- [<%- extension.name %>](https://marketplace.visualstudio.com/items?itemName=<%- extension.id %>): <%- extension.description -%>
<% if (extension.settings) { %>
<%- `${extension.settings}` -%>
<% } %>
<% }); -%>
<% }); -%>

<%- include('partials/footer.ejs'); -%>
