{
  "customizations": {
    "vscode": {
      "extensions": [
        "Grafana.grafana-alloy",
        "Grafana.vscode-jsonnet",
        "jasonlhy.hungry-delete",
        "GitHub.vscode-pull-request-github",
        "GitLab.gitlab-workflow",
        "EdwinHuiSH.better-comments-next",
        "ms-vscode-remote.vscode-remote-extensionpack",
        "stylelint.vscode-stylelint",
        "FanaticPythoner.better-todo-tree",
        "redhat.vscode-xml",
        "timonwong.shellcheck",
        "mhutchie.git-graph",
        "streetsidesoftware.code-spell-checker",
        "qcz.text-power-tools",
        "mikestead.dotenv",
        "dbaeumer.vscode-eslint",
        "tamasfe.even-better-toml",
        "DavidAnson.vscode-markdownlint",
        "esbenp.prettier-vscode",
        "richie5um2.vscode-sort-json",
        "Tyriar.sort-lines",
        "PascalReitermann93.vscode-yaml-sort",
        "usernamehw.errorlens",
        "yzhang.markdown-all-in-one",
        "christian-kohler.path-intellisense",
        "yoavbls.pretty-ts-errors",
        "redhat.vscode-yaml",
        "Catppuccin.catppuccin-vsc",
        "Catppuccin.catppuccin-vsc-icons",
        "pranaygp.vscode-css-peek",
        "JohnnyMorganz.stylua",
        "sumneko.lua",
        "vscodevim.vim",
        "EditorConfig.EditorConfig",
        "mads-hartmann.bash-ide-vscode",
        "mathematic.vscode-pdf"
      ],
      "settings": {
        "[jsonnet]": {
          "editor.defaultFormatter": "Grafana.vscode-jsonnet"
        },
        "[markdown]": {
          "files.trimTrailingWhitespace": false
        },
        "[shellscript]": {
          "editor.rulers": [
            80
          ],
          "editor.defaultFormatter": "mads-hartmann.bash-ide-vscode"
        },
        "chat.disableAIFeatures": true,
        "editor.codeActionsOnSave": {
          "source.addMissingImports": "explicit",
          "source.fixAll.stylelint": "explicit",
          "source.fixAll.eslint": "explicit"
        },
        "editor.fontFamily": "'JetBrainsMonoNL Nerd Font Mono', 'monospace', monospace",
        "editor.fontSize": 18,
        "editor.formatOnPaste": true,
        "editor.formatOnSave": true,
        "editor.guides.bracketPairs": "active",
        "editor.inlayHints.enabled": "offUnlessPressed",
        "editor.linkedEditing": true,
        "editor.stickyScroll.enabled": false,
        "editor.unicodeHighlight.ambiguousCharacters": true,
        "editor.unicodeHighlight.invisibleCharacters": true,
        "files.autoSave": "onFocusChange",
        "files.insertFinalNewline": true,
        "files.trimFinalNewlines": true,
        "files.trimTrailingWhitespace": true,
        "git.blame.editorDecoration.enabled": true,
        "git.blame.ignoreWhitespace": true,
        "git.blame.statusBarItem.enabled": true,
        "git.enableSmartCommit": true,
        "git.openRepositoryInParentFolders": "always",
        "git.smartCommitChanges": "tracked",
        "js/ts.preferences.importModuleSpecifier": "non-relative",
        "workbench.settings.alwaysShowAdvancedSettings": true,
        "workbench.startupEditor": "none",
        "css.validate": false,
        "less.validate": false,
        "scss.validate": false,
        "stylelint.validate": [
          "css",
          "postcss",
          "scss",
          "less",
          "javascriptreact",
          "typescriptreact"
        ],
        "[xml]": {
          "editor.defaultFormatter": "redhat.vscode-xml"
        },
        "shellcheck.ignorePatterns": {
          "**/*.csh": true,
          "**/*.cshrc": true,
          "**/*.env.*": true,
          "**/*.fish": true,
          "**/*.login": true,
          "**/*.logout": true,
          "**/*.profile": true,
          "**/*.tcsh": true,
          "**/*.tcshrc": true,
          "**/*.xonshrc": true,
          "**/*.xsh": true,
          "**/*.zlogin": true,
          "**/*.zlogout": true,
          "**/*.zprofile": true,
          "**/*.zsh": true,
          "**/*.zsh-theme": true,
          "**/*.zshenv": true,
          "**/*.zshrc": true,
          "**/zlogin": true,
          "**/zlogout": true,
          "**/zprofile": true,
          "**/zshenv": true,
          "**/zshrc": true
        },
        "cSpell.diagnosticLevel": "Hint",
        "files.associations": {
          "*.env.*": "dotenv"
        },
        "[toml]": {
          "editor.defaultFormatter": "tamasfe.even-better-toml"
        },
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "vscode-yaml-sort.forceQuotes": true,
        "vscode-yaml-sort.quotingType": "\"",
        "vscode-yaml-sort.sortArrays": true,
        "js/ts.suggest.paths": false,
        "[yaml]": {
          "editor.defaultFormatter": "redhat.vscode-yaml"
        },
        "redhat.telemetry.enabled": false,
        "editor.semanticHighlighting.enabled": true,
        "terminal.integrated.minimumContrastRatio": 1,
        "window.titleBarStyle": "custom",
        "workbench.colorTheme": "Catppuccin Mocha",
        "workbench.iconTheme": "catppuccin-mocha",
        "[lua]": {
          "editor.defaultFormatter": "JohnnyMorganz.stylua"
        },
        "Lua.format.enable": false,
        "bashIde.shellcheckPath": ""
      }
    }
  }
}